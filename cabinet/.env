# ── Локальная разработка (dev) ────────────────────────────────

# API: пусто → запросы идут на относительный /api, который Vite-прокси
# (vite.config.ts) форвардит на рабочий прод-API https://api.butonshop.ru.
# Локального бэка на :3001 нет, поэтому именно прокси, а не прямой URL.
# В prod задаётся в .env.production (https://api.butonshop.ru)
VITE_API_BASE=

# URL магазина (nuxt-shop в dev слушает :3004)
VITE_SHOP_URL=http://localhost:3004
