NUXT_DEV_HOST=172.17.0.1

# ── Локальная разработка (dev) ────123────────────────────────────

# URL публичного сайта (для canonical, sitemap, JSON-LD)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# URL личного кабинета
NUXT_PUBLIC_CABINET_URL=http://localhost:3003

# ── API ────────────────────────────────────────────────────────
# Server-side (SSR): прокси routeRules и server routes (sitemap)
# dev указывает на рабочий прод-API, чтобы тянуть реальные товары/баннеры/картинки
NUXT_API_BASE=https://api.butonshop.ru

# Client-side (браузер): прямые запросы к API (картинки, useFetch с apiBase)
# Здесь — для dev. В prod задаётся в .env.production (https://api.butonshop.ru)
NUXT_PUBLIC_API_BASE=

# WebSocket URL для чата (socket.io) — браузер подключается напрямую к API
# Здесь — для dev. В prod задаётся в .env.production (https://api.butonshop.ru)
NUXT_PUBLIC_WS_BASE=http://localhost:3001
