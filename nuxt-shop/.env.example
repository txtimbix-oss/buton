# ── Продакшн URL ──────────────────────────────────────────────
# URL публичного сайта (для canonical, sitemap, JSON-LD)
NUXT_PUBLIC_SITE_URL=https://front.spbapp.ru

# URL личного кабинета (используется в ссылках на сайте)
NUXT_PUBLIC_CABINET_URL=https://cabinet.spbapp.ru

# ── API ────────────────────────────────────────────────────────
# Server-side (SSR): URL backend-сервера для sitemap и прокси routeRules
# Если nuxt и api на одном сервере — оставить localhost:3001
NUXT_API_BASE=http://localhost:3001

# Client-side (браузер): оставить пустым — запросы идут через proxy /api/**
# Или указать https://api.spbapp.ru если нет прокси-сервера
NUXT_PUBLIC_API_BASE=
