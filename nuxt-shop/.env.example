# ── Продакшн URL ──────────────────────────────────────────────
# URL публичного сайта (для canonical, sitemap, JSON-LD)
NUXT_PUBLIC_SITE_URL=https://butonshop.ru

# URL личного кабинета (используется в ссылках на сайте)
NUXT_PUBLIC_CABINET_URL=https://user.butonshop.ru

# ── API ────────────────────────────────────────────────────────
# Server-side (SSR): production API origin for Nitro proxy
NUXT_API_BASE=https://api.butonshop.ru

# Client-side (браузер): absolute API URL only for explicit helpers
NUXT_PUBLIC_API_BASE=https://api.butonshop.ru

# WebSocket URL для чата (socket.io) — браузер подключается напрямую к API
NUXT_PUBLIC_WS_BASE=https://api.butonshop.ru
